# ============================================================================
# X4 Forge — environment template
#
# Copy this file to `.env.local` and fill in YOUR OWN values.
# `.env`, `.env.local`, and every other `.env*` file are gitignored —
# only this `.env.example` template is ever committed.
#
# SECURITY MODEL (how your keys stay yours):
#   - Server keys below are read only by the local API server (binds 127.0.0.1)
#     and are only used for requests originating from the app UI in YOUR
#     browser (Origin-gated). External scripts/agents must send their own key
#     via the `x-custom-api-key` header — they can never spend these keys.
#   - Keys entered in the in-app "AI Providers" settings are stored SERVER-SIDE
#     in the gitignored `data/ai-keys.json` (write-only API; the browser keeps
#     no copy and can only read a configured-yes/no status). Legacy localStorage
#     keys migrate to the server store on app boot and are purged.
#   - Keys are sent ONLY to the respective provider's official API endpoint.
# ============================================================================

# --- AI providers (all optional — configure only the ones you use) ---------
# You can also skip this file entirely and enter keys in the in-app
# AI Providers settings modal instead (stored in browser localStorage).
GEMINI_API_KEY=""
OPENROUTER_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
# OpenRouter is also read under the alias OPEN_ROUTER_API_KEY (with underscores)
# as a fallback; prefer OPENROUTER_API_KEY above.
# OPEN_ROUTER_API_KEY=""

# --- GitHub integration (optional) ------------------------------------------
# OAuth App Client ID for the one-click "Connect with GitHub" device flow.
# This is a PUBLIC identifier, not a secret — but it's yours, so it lives here.
# Create one at https://github.com/settings/developers (enable Device Flow).
GITHUB_CLIENT_ID=""

# --- Studio API token (optional) --------------------------------------------
# If set, the local API uses this stable token instead of generating a new one
# per server start (saves a page reload after restarts). Any random string.
# STUDIO_API_TOKEN=""

# --- Path overrides (optional — normally set via the in-app Settings modal,
#     which writes them to the gitignored config.json) -----------------------
# X4_GAME_PATH="C:\Program Files (x86)\Steam\steamapps\common\X4 Foundations"
# X4_XSD_PATH="C:\path\to\extracted\X4\Schemas"

# --- Server runtime (optional — sensible defaults; the VS Code extension sets
#     these for its managed sidecar, so you rarely touch them by hand) --------
# HTTP port the local API server binds on 127.0.0.1 (default 3000).
# PORT="3000"
# Runtime data root (agent keys, AI keys, spend meter, harvested schemas). The
# extension points this at its globalStorage so data survives extension updates.
# X4_DATA_DIR=""
# Directory-settings (config.json) location. Extension → globalStorage; NOT
# coupled to X4_STATE_DIR (which the ephemeral/e2e stack sets).
# X4_CONFIG_DIR=""
# Ephemeral workspace-state dir. The e2e harness sets this to isolate the live
# workspace — do not set it by hand for normal use.
# X4_STATE_DIR=""
# Optional override for the (optional) neural-link bridge health URL.
# FORGE_BRIDGE_URL=""

# --- Spending / security backstops (optional) -------------------------------
# Daily cap on the NUMBER of AI provider calls (runaway-spend backstop at the
# single callMultiProviderAI chokepoint). Default 300. Counts calls, not dollars.
# AI_DAILY_CALL_CAP="300"
# Optional daily ESTIMATED-DOLLAR backstop (B64-SEC4). 0/unset = disabled (default;
# only the call cap applies). When >0, the chokepoint also soft-stops once the day's
# estimated spend crosses this many USD. Estimate only (coarse per-model pricing), a
# runaway-dollar guard — not billing. Per-provider rollup shown at GET /api/ai/usage.
# AI_DAILY_USD_CAP="0"
# ⚠ SECURITY: enables the dev-only /api/run_command route (arbitrary shell
# execution) even under NODE_ENV=production. Leave UNSET in any packaged/shared
# build. Only the studio session token may reach that route (agent keys are
# denied on every scope). Set to "true" ONLY on a trusted dev machine.
# FORGE_ALLOW_RUN_COMMAND=""
# Production API-only mode (serves the API + static bundle, no Vite dev server).
# The packaged extension/build sets this; leave unset for local `dev:api`/`dev:web`.
# API_ONLY=""
# NODE_ENV="production" additionally disables /api/run_command unless the flag
# above is set. Development is the default when unset.
