{
  "name": "x4_forge",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore \"**/*.md\" --ignore \"**/*.log\" --ignore \"**/*.txt\" --ignore \"**/.lint-*.json\" --ignore \"**/.snapshots/**\" --ignore \"**/dist/**\" --ignore \"**/temp_import/**\" --ignore \"**/.studio-api-token\" --ignore \"**/data/**\" --ignore \"**/test-results/**\" --ignore \"**/playwright-report/**\" --ignore \"**/graphify-out/**\" server.ts",
    "dev:api": "tsx watch --ignore \"**/*.md\" --ignore \"**/*.log\" --ignore \"**/*.txt\" --ignore \"**/.lint-*.json\" --ignore \"**/.snapshots/**\" --ignore \"**/dist/**\" --ignore \"**/temp_import/**\" --ignore \"**/.studio-api-token\" --ignore \"**/data/**\" --ignore \"**/test-results/**\" --ignore \"**/playwright-report/**\" --ignore \"**/graphify-out/**\" server.ts",
    "dev:web": "vite",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "eslint src server.ts",
    "typecheck": "tsc --noEmit",
    "validate:mod": "tsx scripts/x4validate.ts",
    "start:prod": "set NODE_ENV=production&& node dist/server.cjs",
    "precommit:check": "node scripts/precommit-check.mjs",
    "test:canvas": "node scripts/run-e2e.mjs tests/e2e/canvas-interactions.spec.ts tests/e2e/canvas-coverage.spec.ts",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:routes": "node scripts/route-integration.mjs",
    "test:oracles": "node scripts/oracle-integration.mjs",
    "test:reference-api": "node scripts/reference-api-integration.mjs",
    "test:reference-corpus": "tsx scripts/reference-corpus-check.ts",
    "test:schema-intelligence": "tsx scripts/schema-intelligence-check.ts"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/state": "^6.7.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.6",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@xmldom/xmldom": "^0.9.10",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fast-xml-parser": "^5.8.0",
    "luaparse": "^0.3.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.61.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.2.3"
  }
}
