{
  "name": "x4-forge",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore \"**/*.md\" --ignore \"**/*.log\" --ignore \"**/.snapshots/**\" --ignore \"**/dist/**\" --ignore \"**/temp_import/**\" --ignore \"**/.studio-api-token\" server.ts",
    "dev:api": "tsx watch --ignore \"**/*.md\" --ignore \"**/*.log\" --ignore \"**/.snapshots/**\" --ignore \"**/dist/**\" --ignore \"**/temp_import/**\" --ignore \"**/.studio-api-token\" server.ts",
    "dev:web": "vite",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "eslint src server.ts",
    "typecheck": "tsc --noEmit",
    "precommit:check": "node scripts/precommit-check.mjs",
    "test:canvas": "playwright test tests/e2e/canvas-interactions.spec.ts tests/e2e/canvas-coverage.spec.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@xmldom/xmldom": "^0.9.10",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fast-xml-parser": "^5.8.0",
    "luaparse": "^0.3.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.61.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.2.3"
  }
}
