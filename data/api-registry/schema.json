{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "forge-external-api/v1",
  "title": "Forge external API definition",
  "description": "A drop-in definition of a third-party X4 community library API that Forge's validators use. Mirror this file's name on the extension id, e.g. sn_mod_support_apis.json. Editors that honor $schema will validate on save; the server also runs validateApiDefinition at load and reports failures.",
  "type": "object",
  "required": ["extensionId", "components"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "extensionId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+$",
      "description": "The content.xml id X4 matches dependencies on (case-insensitive)."
    },
    "name": { "type": "string" },
    "author": { "type": "string" },
    "source": { "type": "string" },
    "dependsOn": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Other extension ids this API needs; the validator enforces these transitively."
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "symbols"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "windowsOnly": { "type": "boolean" },
          "requiresProtectedUiDisabled": { "type": "boolean" },
          "symbols": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "kind", "detect"],
              "additionalProperties": true,
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "kind": {
                  "type": "string",
                  "enum": ["md_cue", "lua_event", "lua_global", "lua_callback", "ui_signal"]
                },
                "summary": { "type": "string" },
                "detect": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 },
                  "description": "Literal substrings whose presence in a project's MD/Lua means the symbol is used. Keep specific to avoid false positives."
                },
                "scaffold": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
